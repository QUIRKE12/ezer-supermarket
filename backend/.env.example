# Copy to .env and fill in real values. Never commit .env.

# MongoDB Atlas (GigoInventory DB)
MONGODB_URI=

# JWT for staff (admin/rider) sessions issued by our own backend
JWT_SECRET=

# Firebase Admin SDK (project used for staff Auth + Firestore + FCM + Storage)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# MTN Mobile Money Rwanda - Collections API
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_ENVIRONMENT=sandbox

# Google Maps Distance Matrix API (delivery fee calculation)
GOOGLE_MAPS_API_KEY=

# Firebase Cloud Messaging server key (legacy HTTP API) or use Admin SDK messaging
FCM_SERVER_KEY=

PORT=5000

# Origin used for delivery distance calculations
STORE_ORIGIN_ADDRESS="Murambi Cell, Gatenga Sector, Kicukiro District, Kigali, Rwanda"
